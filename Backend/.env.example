ENV=development

#SERVER
PORT=3000
SERVER_URL=http://localhost:3000

#Database local
# DATABASE_URL="mongodb://localhost:27017/base"
DATABASE_URL=""

#Migration
MIGRATE_MONGO_URI="mongodb://localhost:27017/base"
MIGRATE_AUTOSYNC="true"

#BCRYPT
SALT_ROUNDS="10"

#EMAIL_SERVICE
EMAIL_SERVICE_API_KEY=""

#tokens
ACCESS_TOKEN_SECRET=""
REFRESH_TOKEN_SECRET=""

# ─── AI PLATFORM ────────────────────────────────────────────────────────────────

# Groq LLM  (https://console.groq.com)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Serper Search API  (https://serper.dev)
SERPER_API_KEY=""

# YouTube Data API v3  (https://console.cloud.google.com)
YOUTUBE_API_KEY=""

# Redis  (for BullMQ job queue)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# RAG / Vector store
VECTOR_STORE_PATH="./data/vector-store.json"
RAG_TOP_K="5"
RAG_SIMILARITY_THRESHOLD="0.15"

# Scraper settings
SCRAPER_TIMEOUT_MS="15000"
SCRAPER_MAX_RETRIES="3"
SCRAPER_CONCURRENCY="5"

# CORS – comma-separated allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
